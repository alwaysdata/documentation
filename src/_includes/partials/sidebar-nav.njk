{#- Sidebar Navigation Content - Used in both desktop and mobile sidebars -#}

{#- Main Menu -#}
{% if navigation.main %}
  <ul class="mb-6 space-y-1">
    {% for item in navigation.main %}
      <li>
        <a href="{{ item.url | locale_url }}" class="block rounded-md px-3 py-2 font-medium text-slate-700 no-underline hover:bg-slate-100 dark:text-neutral-300 dark:hover:bg-neutral-800
          {% if page.url == item.url | locale_url %}bg-slate-100 text-slate-900 dark:bg-neutral-800 dark:text-white{% endif %}"
        >
          {{ item.text[page.lang] }}
        </a>
      </li>
    {% endfor %}
  </ul>
  <hr class="mb-6 border-slate-200 dark:border-neutral-800">
{% endif %}

{#- Documentation Navigation -#}
{% set navPages = collections.all | pageLang | eleventyNavigation %}

{% macro renderNavSubListItem(entry) -%}
  <li{% if entry.url == page.url %} class="active"{% endif %}>
    <a href="{{ entry.url }}">{{ entry.title }}</a>
  {%- if entry.children.length -%}
    <ul class="hidden">
      {%- for child in entry.children %}{{ renderNavSubListItem(child) }}{% endfor -%}
    </ul>
  {%- endif -%}
  </li>
{%- endmacro %}
<ul>
{%- for entry in navPages %}
  <li>
    {%- if entry.children.length -%}
      <details {% if (entry.url == page.url) or (activeChild == true) %}open{% endif %}>
        <summary>
          <a {% if entry.url == page.url %} class="active"{% endif %} href="{{ entry.url }}">{{ entry.key }}</a>
          {% phosphor "caret-right", "regular", { size: 20 } %}
        </summary>
        <ul>
          {%- for child in entry.children %}
          <li>
            <a {% if child.url == page.url %} class="active"{% endif %} href="{{ child.url }}">{{ child.key }}</a>
            {%- if child.children.length -%}
            <ul class="hidden">
              {%- for child in child.children %}
              {{ renderNavSubListItem(child) }}
              {% endfor -%}
            </ul>
            {%- endif -%}
          </li>
          {% endfor -%}
        </ul>
      </details>
    {% else %}
      <a {% if entry.url == page.url %} class="active"{% endif %} href="{{ entry.url }}">{{ entry.key }}</a>
    {%- endif -%}
  </li>
{%- endfor %}
</ul>

{#- Legal Links -#}
{% if navigation.legal %}
  <hr class="my-6 border-slate-200 dark:border-neutral-800">
  <ul class="space-y-1">
    {% for item in navigation.legal %}
      <li>
        <a href="{{ item.url | locale_url }}" class="block rounded-md px-3 py-2 font-medium text-slate-700 no-underline hover:bg-slate-100 dark:text-neutral-300 dark:hover:bg-neutral-800
          {% if page.url == item.url | locale_url %}bg-slate-100 text-slate-900 dark:bg-neutral-800 dark:text-white{% endif %}"
        >
          {{ item.text[page.lang] }}
        </a>
      </li>
    {% endfor %}
  </ul>
{% endif %}
