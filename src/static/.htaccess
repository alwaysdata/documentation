ErrorDocument 404 /404.html

### Redirect based on locales
RewriteEngine On
RewriteCond %{HTTP:Accept-Language} ^fr [NC]
RewriteRule ^$ /fr/ [L]
RewriteCond %{HTTP:Accept-Language} ^en [NC]
RewriteRule ^$ /en/ [L]

# Exceptions
RewriteRule ^(fr|en)/blog(/.*)?$ - [L]
RewriteRule ^(fr|en)/love(/.*)?$ - [L]

# Redirect all other doc pages
RewriteRule ^(fr|en)/(?!docs/)(.+)$ /$1/docs/$2 [R=301,L]

# Rewriting url for FR
RewriteCond %{HTTP:Accept-Language} ^fr [NC]
RewriteRule ^love/?$  /fr/love/ [QSA,L,R=307]
RewriteCond %{HTTP:Accept-Language} ^fr [NC]
RewriteRule ^_love/?$  /fr/love/ [QSA,L,R=307]
RewriteCond %{HTTP:Accept-Language} ^fr [NC]
RewriteRule ^aac/?$   /fr/docs/admin-facturation/programmes/academic-cloud/ [QSA,L,R=307]
RewriteCond %{HTTP:Accept-Language} ^fr [NC]
RewriteRule ^_aac/?$   /fr/docs/admin-facturation/programmes/academic-cloud/ [QSA,L,R=307]
RewriteCond %{HTTP:Accept-Language} ^fr [NC]
RewriteRule ^cloud/?$ /fr/docs/admin-facturation/facturation/prix-cloud-public/ [QSA,L,R=307]
RewriteCond %{HTTP:Accept-Language} ^fr [NC]
RewriteRule ^_cloud/?$ /fr/docs/admin-facturation/facturation/prix-cloud-public/ [QSA,L,R=307]
RewriteCond %{HTTP:Accept-Language} ^fr [NC]
RewriteRule ^_private_prices/?$ /fr/docs/admin-facturation/facturation/prix-cloud-prive/ [QSA,L,R=307]
RewriteCond %{HTTP:Accept-Language} ^fr [NC]
RewriteRule ^_alerts/?$ /fr/docs/admin-facturation/profil/systeme-dalertes/ [QSA,L,R=307]
RewriteCond %{HTTP:Accept-Language} ^fr [NC]
RewriteRule ^_migrations/?$ /fr/docs/caracteristiques-techniques/migrations/effectuer-une-migration/ [QSA,L,R=307]
RewriteCond %{HTTP:Accept-Language} ^fr [NC]
RewriteRule ^_tickets/?$ /fr/docs/admin-facturation/ticket-urgent/ [QSA,L,R=307]
RewriteCond %{HTTP:Accept-Language} ^fr [NC]
RewriteRule ^_domains/?$ /fr/docs/domaines/problemes-frequents/ [QSA,L,R=307]
RewriteCond %{HTTP:Accept-Language} ^fr [NC]
RewriteRule ^marketplace-script/?$ /fr/docs/developpement/marketplace/creer-script-dapplication/ [QSA,L,R=307]
RewriteCond %{HTTP:Accept-Language} ^fr [NC]
RewriteRule ^log-http/?$ /fr/docs/hebergement-web/sites/formater-les-logs-http/ [QSA,L,R=307]
RewriteCond %{HTTP:Accept-Language} ^fr [NC]
RewriteRule ^/?$ /fr/ [QSA,L,R=307]
RewriteCond %{HTTP:Accept-Language} ^fr [NC]
RewriteRule ^green/?$  /fr/docs/caracteristiques-techniques/green-hosting/ [QSA,L,R=307]
RewriteCond %{HTTP:Accept-Language} ^fr [NC]
RewriteRule ^api/?$  /fr/docs/developpement/api/ [QSA,L,R=307]
RewriteCond %{HTTP:Accept-Language} ^fr [NC]
RewriteRule ^signin-issues/?$  /fr/docs/admin-facturation/profil/perte-dacces-admin/ [QSA,L,R=307]
RewriteCond %{HTTP:Accept-Language} ^fr [NC]
RewriteRule ^bug-bounty/?$  /fr/docs/caracteristiques-techniques/bug-bounty/ [QSA,L,R=307]


# Rewriting url for all languages (EN default)
RewriteRule ^love/?$  /en/love/ [QSA,L,R=307]
RewriteRule ^_love/?$  /en/love/ [QSA,L,R=307]
RewriteRule ^aac/?$   /en/docs/admin-billing/programs/academic-cloud/ [QSA,L,R=307]
RewriteRule ^_aac/?$   /en/docs/admin-billing/programs/academic-cloud/ [QSA,L,R=307]
RewriteRule ^cloud/?$ /en/docs/admin-billing/billing/public-cloud-prices/ [QSA,L,R=307]
RewriteRule ^_cloud/?$ /en/docs/admin-billing/billing/public-cloud-prices/ [QSA,L,R=307]
RewriteRule ^_private_prices/?$ /en/docs/admin-billing/billing/private-cloud-prices/ [QSA,L,R=307]
RewriteRule ^_alerts/?$ /en/docs/admin-billing/profile/alerts-notifications/ [QSA,L,R=307]
RewriteRule ^_migrations/?$ /en/docs/technical-specifications/migrations/perform-migration/ [QSA,L,R=307]
RewriteRule ^_tickets/?$ /en/docs/admin-billing/urgent-ticket/ [QSA,L,R=307]
RewriteRule ^_domains/?$ /en/docs/domains/troubleshooting/ [QSA,L,R=307]
RewriteRule ^marketplace-script/?$ /en/docs/development/marketplace/build-application-script/ [QSA,L,R=307]
RewriteRule ^log-http/?$ /en/docs/web-hosting/sites/formatting-http-logs/ [QSA,L,R=307]
RewriteRule ^green/?$  /en/docs/technical-specifications/green/ [QSA,L,R=307]
RewriteRule ^api/?$  /en/docs/development/api/ [QSA,L,R=307]
RewriteRule ^signin-issues/?$  /en/docs/admin-billing/profile/admin-access-loss/ [QSA,L,R=307]
RewriteRule ^bug-bounty/?$  /en/docs/technical-specifications/bug-bounty/ [QSA,L,R=307]

## Redirects footer
Redirect 301 /fr/securite/bug-bounty/ /fr/docs/caracteristiques-techniques/bug-bounty/
Redirect 301 /en/security/bug-bounty/ /en/docs/technical-specifications/bug-bounty/

## Redirects install scripts
Redirect 301 /en/marketplace/build-application-script/ /en/docs/development/marketplace/build-application-script/

## Redirects website
Redirect 301 /fr/comptes/restrictions-du-cloud-public/ /fr/docs/admin-facturation/profil/suspension/
Redirect 301 /en/admin-billing/public-cloud-restrictions/ /en/docs/admin-billing/profile/suspension/
